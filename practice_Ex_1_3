#include <stdio.h>

int queue[10];
int front = -1, rear = -1;

int main() {
    int choice, pid;

    while (1) {
        printf("\n1. Add Process\n");
        printf("2. Execute Process\n");
        printf("3. Display Queue\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        if (choice == 1) {
            printf("Enter Process ID: ");
            scanf("%d", &pid);

            if (rear == 9)
                printf("Queue is Full\n");
            else {
                if (front == -1)
                    front = 0;
                rear++;
                queue[rear] = pid;
                printf("Process %d Added\n", pid);
            }
        }

        else if (choice == 2) {
            if (front == -1 || front > rear)
                printf("Queue is Empty\n");
            else {
                printf("Executing Process %d\n", queue[front]);
                front++;
            }
        }

        else if (choice == 3) {
            if (front == -1 || front > rear)
                printf("Queue is Empty\n");
            else {
                printf("Ready Queue: ");
                for (int i = front; i <= rear; i++)
                    printf("%d ", queue[i]);
                printf("\n");
            }
        }

        else if (choice == 4) {
            break;
        }

        else {
            printf("Invalid Choice\n");
        }
    }

    return 0;
}
