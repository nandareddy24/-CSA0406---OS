#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>

int main() {
    pid_t child1, child2;

    // Create first child
    child1 = fork();

    if (child1 == 0) {
        // First child process
        printf("First Child Process\n");
        printf("PID = %d, Parent PID = %d\n", getpid(), getppid());
        return 0;
    }

    // Create second child
    child2 = fork();

    if (child2 == 0) {
        // Second child process
        printf("Second Child Process\n");
        printf("PID = %d, Parent PID = %d\n", getpid(), getppid());
        return 0;
    }

    // Parent process
    printf("Parent Process\n");
    printf("PID = %d\n", getpid());

    return 0;
}
